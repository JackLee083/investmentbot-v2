# Copy this file to .env and fill in real values. Never commit .env.

# --- Notion (datastore/dashboard, retired after v3 migration) ---
NOTION_TOKEN=your_notion_integration_token

# --- Market data ---
ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key

# --- Kraken (crypto exchange, ccxt) ---
KRAKEN_KEY=your_kraken_api_key
KRAKEN_SECRET=your_kraken_api_secret

# --- DCA strategy sizing ---
BASE_AMOUNT=1000
DCA_STOCK_TICKER=GOOG

# --- IBKR / IB Gateway connection ---
IBKR_HOST=ib-gateway   # compose service name; do not use an IP -- Docker's internal DNS resolves this
IBKR_PORT=4004         # gnzsnz ib-gateway socat port INSIDE the container: paper=4004, live=4003.
                        # Must match TRADING_MODE below -- at live cutover flip BOTH together:
                        # TRADING_MODE=live + IBKR_PORT=4003.
                        # VERIFY the actual port on your image/version before relying on this:
                        # docker exec ib-gateway ss -tlnp
IBKR_CLIENT_ID=11

# --- LINE Messaging API (outbound push notifications) ---
LINE_ACCESS_TOKEN=your_line_channel_access_token
# no longer used by code after v3 Phase 4 -- kept for reference until you delete the webhook in LINE console
LINE_CHANNEL_SECRET=your_line_channel_secret

# Recipient ID lists must be JSON arrays of LINE user/group IDs, e.g. ["U123...", "U456..."]
ADMIN_IDS=["U_admin_line_user_id"]
REPORT_VIEWER_IDS=["U_report_viewer_line_user_id"]
SIGNAL_VIEWER_IDS=["U_signal_viewer_line_user_id"]

# --- IB Gateway container login (ghcr.io/gnzsnz/ib-gateway) ---
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password
TRADING_MODE=paper  # paper | live

# --- Cloudflare tunnel ---
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# --- IB Gateway VNC access password ---
VNC_PASSWORD=choose_a_strong_password

# --- Dashboard auth (web/, Phase 3+) ---
DASHBOARD_PASSWORD_HASH=werkzeug_generated_password_hash
FLASK_SECRET_KEY=random_secret_key_for_session_signing
